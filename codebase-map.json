    "kempnerforge/config/registry.py": {
      "classes": {
        "Registry": {
          "purpose": "Central registry for named components (models, optimizers, schedulers, losses, evaluators)",
          "methods": [
            "register(category, name, obj)",
            "get(category, name)",
            "list(category)",
            "register_model(name)",
            "get_model(name)",
            "register_optimizer(name)",
            "get_optimizer(name)",
            "register_scheduler(name)",
            "get_scheduler(name)",
            "register_loss(name)",
            "get_loss(name)",
            "register_eval(name)",
            "get_eval(name)"
          ]
        }
      },
      "globals": ["registry: Registry"],
      "tested_by": ["tests/unit/test_config.py::TestRegistry"]
    },
    "kempnerforge/config/schema.py": {
      "enums": ["NormType", "Activation", "ActivationCheckpointing", "AsyncCheckpointMode", "PipelineSchedule", "SchedulerType"],
      "classes": {
        "ModelConfig": {
          "purpose": "Architecture hyperparameters (dim, layers, heads, vocab, MoE, QK-norm)",
          "properties": ["is_moe", "head_dim", "computed_ffn_hidden_dim", "num_params_estimate"]
        },
        "TrainConfig": {
          "purpose": "Training hyperparameters (steps, batch, seq_len, precision, loss, grad accum)",
          "properties": ["param_dtype", "is_fp8"]
        },
        "OptimizerConfig": {
          "purpose": "Optimizer settings (name, lr, betas, weight_decay, muon params, schedule_free_warmup_steps)"
        },
        "SchedulerConfig": {
          "purpose": "LR schedule (type, warmup, min_lr_ratio, WSD params, wsd_decay_type, rex_alpha)"
        },
        "DatasetSource": {
          "purpose": "Single data source in a multi-dataset mixture (path or HF, weight, name)"
        },
        "TrainingPhase": {
          "purpose": "Step-triggered phase with dataset weight overrides and LR scaling for data annealing"
        },
        "DataConfig": {
          "purpose": "Data pipeline (dataset_path, HF dataset, tokenizer, packing, mixing, phases, annealing)"
        },
        "EvalConfig": {
          "purpose": "Evaluation pipeline (interval, steps, data source)"
        },
        "DistributedConfig": {
          "purpose": "Parallelism dimensions (tp, pp, cp, ep, dp_replicate, dp_shard, fsdp)",
          "methods": ["validate_world_size(world_size)", "resolve(world_size)"]
        },
        "CheckpointConfig": {
          "purpose": "Checkpointing (dir, interval, keep, async mode)"
        },
        "MetricsConfig": {
          "purpose": "Logging (interval, wandb, tensorboard)"
        },
        "ProfilingConfig": {
          "purpose": "Performance profiling (torch.profiler settings)"
        },
        "JobConfig": {
          "purpose": "Top-level config aggregating all sub-configs",
          "methods": ["validate(world_size)"]
        }
      },
      "tested_by": [
        "tests/unit/test_config.py::TestModelConfig",
